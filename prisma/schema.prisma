
generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}


model User{
  id String @id @default(cuid())
  clearkId String @unique
  email String @unique
  username String? @unique

  firstName String?
  lastName String?
  imageUrl String?
  bio String? @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}